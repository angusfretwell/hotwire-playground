<p style="color: green"><%= notice %></p>

<h1>Builds</h1>

<div id="builds">
  <% @builds.each do |build| %>
    <%= render build %>
    <p>
      <%= link_to "Show this build", build %>
    </p>
  <% end %>
</div>

<dialog data-controller="dialog" data-action="turbo:frame-load->dialog#showModal">
  <%= turbo_frame_tag :dialog %>
</dialog>

<%= link_to "New build", new_build_path, data: { turbo_frame: :dialog, turbo_action: :advance } %>
